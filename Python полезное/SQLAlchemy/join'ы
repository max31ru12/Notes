В алхимии нет правого Join'a, есть только левый

можно создать таблицам alias'ы: from sqlalchemy.orm import aliased

r = aliased(ResumesOrm) # передаем имя таблицы
w = aliased(WorkersOrm) # передаем имя таблицы

метод .join() по умолчанию LEFT INNNER JOIN
      .join(isouter=True) - сделать внешний JOIN

# Использование (r - левая таблица для JOIN'a)
...join(r, r.worker_id == w.id)


# Если прописаны relationship в моделях, то можно использовать join'ы в запросах таким образом:
!!!!!!!!! ТАКИЕ ВЕЩИ ИСПОЛЬЗУЮТСЯ ВМЕСТО ЛЕНИВОЙ ПОДГРУЗКИ В АСИНХРОННОМ КОДЕ !!!!!!!!!

____ ПОДХОДИТ ДЛЯ 1:1 ИЛИ M:1 ____
from sqlalchemy.orm import joinedload

query = select(WorkersOrm).options(joinedload(WorkersOrm.resumes))

____ ПОДХОДИТ ДЛЯ M:M ИЛИ M:1 ____
from sqlalchemy.orm import selectinload

query = select(WorkersOrm).options(selectinload(WorkersOrm.resumes))


!!! OPTIONS -> contains_eager() !!!
...join().options(contains_eager(WorkersOrm.resumes)) - позволяет не плодить лишний код ()
